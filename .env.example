# =============================================================================
# APPLICATION
# =============================================================================

# Environment: development | testing | production
APP_ENV=development

# Secret key for signing JWTs — generate with: openssl rand -hex 32
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# Algorithm used for JWT signing — HS256 is standard for symmetric keys
JWT_ALGORITHM=HS256

# Access token lifetime in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Password reset token lifetime in minutes — keep short
RESET_TOKEN_EXPIRE_MINUTES=15

# =============================================================================
# DATABASE (PostgreSQL)
# =============================================================================

# PostgreSQL connection details — must match docker-compose.yml service
POSTGRES_USER=iotuser
POSTGRES_PASSWORD=iotpassword
POSTGRES_DB=iotdb
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Full async DSN built from above — used by SQLAlchemy
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://iotuser:iotpassword@db:5432/iotdb

# =============================================================================
# EMAIL (Mailtrap SMTP — development only)
# =============================================================================
# Mailtrap catches all outgoing emails and shows them in a web inbox.
# No real emails are ever delivered. Sign up free at https://mailtrap.io
# In production, replace these values with SendGrid, AWS SES, or any SMTP provider.

MAIL_USERNAME=your-mailtrap-username
MAIL_PASSWORD=your-mailtrap-password
MAIL_FROM=noreply@iot-security-suite.dev
MAIL_PORT=587
MAIL_SERVER=sandbox.smtp.mailtrap.io
MAIL_STARTTLS=True
MAIL_SSL_TLS=False

# =============================================================================
# SECURITY TEST FRAMEWORK
# =============================================================================

# Base URL of the target FastAPI app — used by all test modules
TARGET_BASE_URL=http://app:8000

# How many concurrent workers for brute force simulation tests
BRUTE_FORCE_WORKERS=5

# Request timeout in seconds for TLS and connectivity tests
TEST_REQUEST_TIMEOUT=10

# =============================================================================
# RATE LIMITING
# =============================================================================

# Max login attempts before lockout triggers
RATE_LIMIT_MAX_ATTEMPTS=5

# Window in seconds for rate limit counting
RATE_LIMIT_WINDOW_SECONDS=60
